# LLM Provider Configuration
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.1

# Workflow Engine Configuration
WORKFLOW_MAX_STEPS=20
WORKFLOW_TIMEOUT_SECONDS=300
WORKFLOW_STATE_BACKEND=memory   # memory | file

# File state backend (used when WORKFLOW_STATE_BACKEND=file)
WORKFLOW_STATE_DIR=.workflow_states

# External API Configuration
API_REQUEST_TIMEOUT=30
API_MAX_RETRIES=3
API_RETRY_BACKOFF=2.0

# Validation Configuration
VALIDATION_STRICT_MODE=true
VALIDATION_MAX_ERRORS=10

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json   # json | console

# Document Processing
DOC_MAX_CHUNK_SIZE=2000
DOC_CHUNK_OVERLAP=200
